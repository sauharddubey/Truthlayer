# ─────────────────────────────────────────────────────────────────────────────
# TruthLayer environment configuration  (the "universal" env file)
#
#   cp .env.example .env   then fill in the values below.
#
# This committed template is the single source of truth for every config key.
# `.env` itself is gitignored — never commit real secrets.
#
# THIS FILE CONTAINS NO API KEYS.
#   1. SHARED / INFRA (here): Supabase project, database, encryption key, plus
#      non-secret model/provider config (base URLs, model names). Same for
#      everyone working against a given environment.
#   2. PER-USER (NOT here): each user enters their OWN service API keys
#      (OpenRouter, Tavily, media-integrity) in the app's Settings.
#      They are encrypted at rest (Fernet) and used only for that user's work.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development                  # development | production
BACKEND_CORS_ORIGINS=http://localhost:3000

# Encrypts secrets at rest (per-user OpenRouter keys) and signs media URLs.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=generate-a-fernet-key

# ── Auth: Supabase (Dashboard → Project → Settings → API) ────────────────────
# Sign-up/sign-in (email+password and Google) happen client-side via Supabase.
# Enable the Email and Google providers + redirect URLs in the dashboard.
# The backend verifies access tokens via the project JWKS (ES256) — no secret.
SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# ── Database (Supabase Postgres + pgvector) ──────────────────────────────────
# Use the Session pooler (IPv4) connection string in the SYNC driver form.
DATABASE_URL=postgresql+psycopg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# ── Redis / Celery (optional) ────────────────────────────────────────────────
# Leave REDIS_URL empty to run analysis with FastAPI BackgroundTasks instead of
# a Celery worker (handy for free tiers without a separate worker dyno).
REDIS_URL=redis://redis:6379/0
USE_CELERY=false

# ─────────────────────────────────────────────────────────────────────────────
# NON-SECRET model/provider config below — base URLs, model names, dimensions.
# NO API KEYS live in env. Every key (OpenRouter, Tavily, media-
# integrity) is entered per-user in the app's Settings and stored encrypted.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM (OpenRouter — OpenAI-compatible) ─────────────────────────────────────
#   LLM_MODEL examples:
#     openai/gpt-oss-120b:free                    (FREE, strong, clean JSON — default)
#     openai/gpt-4o-mini                          (paid: cheap, very reliable)
#     meta-llama/llama-3.3-70b-instruct           (paid: strong, low cost)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-oss-120b:free
LLM_TEMPERATURE=0.1
LLM_HTTP_REFERER=https://truthlayer.app    # optional OpenRouter attribution
LLM_APP_TITLE=TruthLayer                    # optional OpenRouter attribution

# ── Embeddings (served by OpenRouter using each user's OpenRouter key) ───────
EMBEDDINGS_PROVIDER=openai               # local | openai
EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1
EMBEDDINGS_MODEL=openai/text-embedding-3-small
EMBEDDINGS_DIM=1536                      # MUST match the model; set BEFORE first run

# ── Transcription ────────────────────────────────────────────────────────────
# Provider: openrouter | stub
#   openrouter — audio-input chat model (uses each user's OpenRouter key)
#   stub       — deterministic placeholder transcript (no key needed)
TRANSCRIPTION_PROVIDER=openrouter
TRANSCRIPTION_MODEL=google/gemini-2.5-flash-lite

# ── Media integrity (Hive deepfake detection) ───────────────────────────────
# Provider adapter for business-tier authenticity scoring. API token is per-user
# in Settings. BACKEND_PUBLIC_URL must be publicly reachable so Hive can fetch
# signed /media/... links.
MEDIA_INTEGRITY_PROVIDER=hive
MEDIA_INTEGRITY_URL=https://api.thehive.ai/api/v3/hive/ai-generated-and-deepfake-content-detection
BACKEND_PUBLIC_URL=http://localhost:8000

# ── Storage ──────────────────────────────────────────────────────────────────
# Where uploaded/downloaded media is stored locally before processing.
MEDIA_STORAGE_DIR=/tmp/truthlayer/media
MAX_UPLOAD_MB=200

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
