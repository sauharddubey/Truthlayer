# ─────────────────────────────────────────────────────────────────────────────
# TruthLayer environment configuration
# Copy this file to `.env` and fill in your keys. All values are placeholders.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development                  # development | production
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080        # 7 days
BACKEND_CORS_ORIGINS=http://localhost:3000

# ── Google OAuth (Sign in with Google) ───────────────────────────────────────
# Create an OAuth 2.0 "Web application" Client ID at
# https://console.cloud.google.com/apis/credentials
# Authorized JS origins: http://localhost:3000 (+ your Vercel URL)
# The SAME client id goes in both vars below (backend verifies, frontend renders).
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# ── Database (Postgres + pgvector) ───────────────────────────────────────────
# Supabase / Neon give you a free Postgres with pgvector. Paste the pooled
# connection string here. Use the SYNC driver form (postgresql+psycopg://...).
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/truthlayer

# ── Redis / Celery (optional) ────────────────────────────────────────────────
# Leave REDIS_URL empty to run analysis with FastAPI BackgroundTasks instead of
# a Celery worker (handy for free tiers without a separate worker dyno).
REDIS_URL=redis://redis:6379/0
USE_CELERY=false

# ── LLM (OpenRouter — all AI reasoning) ──────────────────────────────────────
# OpenRouter is OpenAI-compatible and routes to many models with one key.
# Get a key at https://openrouter.ai/keys
#   LLM_MODEL examples:
#     openai/gpt-oss-120b:free                    (FREE, strong, clean JSON — default)
#     openai/gpt-oss-20b:free                     (FREE, smaller/faster fallback)
#     openai/gpt-4o-mini                          (paid: cheap, very reliable)
#     meta-llama/llama-3.3-70b-instruct           (paid: strong, low cost)
# Free models are rate-limited; add credits at openrouter.ai for higher throughput.
LLM_API_KEY=your-openrouter-api-key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-oss-120b:free
LLM_TEMPERATURE=0.1
LLM_HTTP_REFERER=https://truthlayer.app    # optional OpenRouter attribution
LLM_APP_TITLE=TruthLayer                    # optional OpenRouter attribution

# ── Embeddings ───────────────────────────────────────────────────────────────
# OpenRouter DOES expose an /embeddings endpoint, but there are no FREE embedding
# models, so it needs OpenRouter credits. The default below uses a LOCAL
# sentence-transformers model (no key, no cost) so RAG works out of the box.
#
# To route embeddings through OpenRouter (after adding credits):
#   EMBEDDINGS_PROVIDER=openai
#   EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1
#   EMBEDDINGS_API_KEY=<your OpenRouter key>
#   EMBEDDINGS_MODEL=openai/text-embedding-3-small
#   EMBEDDINGS_DIM=1536      # MUST match the model; set BEFORE first run
EMBEDDINGS_PROVIDER=local                # local | openai
EMBEDDINGS_API_KEY=your-embeddings-api-key
EMBEDDINGS_BASE_URL=https://api.openai.com/v1
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIM=384                       # 384 for local MiniLM, 1536 for OpenAI small

# ── Transcription ────────────────────────────────────────────────────────────
# Provider: openrouter | whisper | stub
#   openrouter — transcribe via an audio-input chat model using your OpenRouter
#                key (audio requires a small OpenRouter credit balance).
#   whisper    — OpenAI-compatible /audio/transcriptions (Groq = free Whisper).
#   stub       — deterministic placeholder transcript (no key needed).
# Any failure (no credits/key) falls back to the stub so the pipeline still runs.
TRANSCRIPTION_PROVIDER=openrouter
TRANSCRIPTION_MODEL=google/gemini-2.5-flash-lite   # audio-capable OpenRouter model
WHISPER_API_KEY=your-groq-or-openai-whisper-key
WHISPER_BASE_URL=https://api.groq.com/openai/v1
WHISPER_MODEL=whisper-large-v3

# ── Evidence retrieval (web search for fact-checking) ────────────────────────
# Optional. Tavily has a free tier and is great for fact-check evidence.
TAVILY_API_KEY=your-tavily-api-key

# ── Media integrity (deepfake / celebrity detection) ─────────────────────────
# Optional external GPU inference endpoint. If unset, heuristic stubs are used.
MEDIA_INTEGRITY_URL=
MEDIA_INTEGRITY_API_KEY=

# ── Storage ──────────────────────────────────────────────────────────────────
# Where uploaded/downloaded media is stored locally before processing.
MEDIA_STORAGE_DIR=/tmp/truthlayer/media
MAX_UPLOAD_MB=200

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
